# .env.example — Broadsheet
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is already in .gitignore).
#
# All keys are free. Sign-up links are listed next to each key.
# See README.md for step-by-step setup instructions.
# ============================================================

# -----------------------------------------------------------
# LLM:gemini-3.1-flash-lite-preview - Primary model
# -----------------------------------------------------------
GEMINI_API_KEY=PLACEHOLDER

# -----------------------------------------------------------
# LLM: Cerebras llama-3.3-70b - Secondary model
# -----------------------------------------------------------
CEREBRAS_API_KEY=PLACEHOLDER

# -----------------------------------------------------------
# LLM: Groq (Tertiary model — Llama 3.3 70B)
# Last-resort scoring tier. Activates only if both Gemini and
# Cerebras fail in the same run.
# Sign up: https://console.groq.com
# After login, go to: API Keys → Create API Key
# Free tier: 14,400 requests/day, 30 requests/minute. No card required.
# Note: optional — if blank, Broadsheet falls through to equal scoring as before.
# -----------------------------------------------------------
GROQ_API_KEY=PLACEHOLDER_your_groq_api_key


# -----------------------------------------------------------
# NEWS: Tavily (AI-powered web search)
# Sign up: https://app.tavily.com
# After login: copy your API key from the dashboard
# Free: 1000 credits/month (~200 searches)
# -----------------------------------------------------------
TAVILY_API_KEY=PLACEHOLDER_your_tavily_api_key


# -----------------------------------------------------------
# NEWS: The Guardian API (for laws & ethics content)
# Sign up: https://open-platform.theguardian.com/access/
# Click "Register for a developer key" — no credit card
# Free: unlimited requests for non-commercial use
# -----------------------------------------------------------
GUARDIAN_API_KEY=PLACEHOLDER_your_guardian_api_key


# -----------------------------------------------------------
# NEWS: ProductHunt (for new AI tool launches)
# Sign up: https://www.producthunt.com/v2/oauth/applications
# Create an application → copy the API token
# Free read-only access
# Note: optional — if blank, ProductHunt source is skipped
# -----------------------------------------------------------
PRODUCTHUNT_API_TOKEN=PLACEHOLDER_your_producthunt_token


# -----------------------------------------------------------
# DELIVERY: Notion
# Step 1 — Create an integration:
#   https://www.notion.so/my-integrations → New integration
#   Name it "Broadsheet", select your workspace
#   Copy the "Internal Integration Secret" below
# Step 2 — Create a database (see README for exact schema)
# Step 3 — Share the database with your integration:
#   Open the database → Share → Invite → select "Broadsheet"
# Step 4 — Copy the database ID from the URL:
#   URL format: notion.so/<workspace>/<DATABASE_ID>?v=...
#   The database ID is the 32-character string before the ?
# -----------------------------------------------------------
NOTION_API_KEY=PLACEHOLDER_your_notion_integration_secret
NOTION_DATABASE_ID=PLACEHOLDER_32_character_database_id

NOTION_VOTES_DATABASE_ID=PLACEHOLDER_32_character_database_id

# Optional: Notion database for candidate audit log (shows which stories
# were considered each run and why they were selected or dropped).
# If not set, candidate logging is silently skipped.
NOTION_CANDIDATES_DATABASE_ID=

# Optional: Notion database for per-run diagnostics (Run Logs). One row per run.
# Captures editor drops, style edits, and source failures, with links shown at
# the top of each email. See briefings/brief-17-run-log-and-scheduling.md for
# the required schema. If not set, run-log writes are silently skipped.
NOTION_RUN_LOG_DATABASE_ID=


# -----------------------------------------------------------
# DELIVERY: Brevo SMTP (transactional email)
# Sign up: https://www.brevo.com (free — 300 emails/day, no trial)
#
# SENDER_EMAIL     — "From" address shown in recipients' inboxes.
#                    Must be verified: Brevo → Senders & IPs → Senders → Add a sender.
# BREVO_SMTP_LOGIN — auto-generated SMTP login shown in Brevo → SMTP & API → SMTP
#                    (looks like ab07f9001@smtp-brevo.com — not your account email)
# BREVO_SMTP_KEY   — generate under Brevo → SMTP & API → SMTP → Generate SMTP key
#                    Shown only once — copy before closing the dialog.
# -----------------------------------------------------------
SENDER_EMAIL=PLACEHOLDER_your@verified-address.com
BREVO_SMTP_LOGIN=PLACEHOLDER_ab07f9001@smtp-brevo.com
BREVO_SMTP_KEY=PLACEHOLDER_xsmtpsib-your-key-here
